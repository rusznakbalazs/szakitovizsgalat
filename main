    let xp = 0;
    const seen = new Set();
    let currentUtterance = null;

    function init() {
        const navList = document.getElementById('nav-list');
        dataset.forEach((group, index) => {
            const div = document.createElement('div');
            div.className = 'nav-item' + (index === 0 ? ' active' : '');
            div.innerText = group.group;
            div.addEventListener('click', () => render(index, div));
            navList.appendChild(div);
        });
        render(0, document.querySelector('.nav-item'));
    }

    function render(index, el) {
        window.speechSynthesis.cancel(); 
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        el.classList.add('active');
        
        const grid = document.getElementById('card-grid');
        grid.innerHTML = '';
        
        dataset[index].items.forEach(item => {
            const card = document.createElement('div');
            card.className = 'card';
            
            const mathHtml = item.math ? `<div class='math-container'>$$ ${item.math} $$</div>` : '';

            card.innerHTML = `
                <div class="card-inner">
                    <div class="face front">
                        <span class="tag">Kattints a kártyára a forgatáshoz!</span>
                        <h3>${item.t}</h3>
                        <span style="font-size: 4rem; opacity: 0.9;">🔄</span>
                        <button class="btn-speaker-front">🔊 Cím felolvasása</button>
                    </div>
                    <div class="face back">
                        <div class="profile-img">${item.svg}</div>
                        <p>${item.d}</p>
                        ${mathHtml}
                        <button class="btn-speaker">🔊 Részletes magyarázat</button>
                    </div>
                </div>
            `;
            
            const inner = card.querySelector('.card-inner');
            const btnBack = card.querySelector('.btn-speaker');
            const btnFront = card.querySelector('.btn-speaker-front');

            inner.addEventListener('click', function(e) {
                if(e.target === btnBack || e.target === btnFront || e.target.tagName.toLowerCase() === 'a') return; 
                
                card.classList.toggle('flipped');
                window.speechSynthesis.cancel(); 
                
                document.querySelectorAll('.btn-speaker, .btn-speaker-front').forEach(b => b.classList.remove('playing'));

                if (card.classList.contains('flipped')) {
                    if (!seen.has(item.t)) {
                        seen.add(item.t);
                        xp += 50;
                        document.getElementById('xp').innerText = xp;
                        updateRank();
                    }
                }
            });

            btnFront.addEventListener('click', function(e) {
                e.stopPropagation(); 
                
                if (window.speechSynthesis.speaking) {
                    window.speechSynthesis.cancel();
                    document.querySelectorAll('.btn-speaker-front').forEach(b => b.classList.remove('playing'));
                } else {
                    document.querySelectorAll('.btn-speaker-front, .btn-speaker').forEach(b => b.classList.remove('playing'));
                    btnFront.classList.add('playing');
                    
                    currentUtterance = new SpeechSynthesisUtterance(item.t);
                    currentUtterance.lang = 'hu-HU';
                    currentUtterance.rate = 0.90; 
                    
                    currentUtterance.onend = function() {
                        btnFront.classList.remove('playing');
                    };
                    
                    window.speechSynthesis.speak(currentUtterance);
                }
            });

            btnBack.addEventListener('click', function(e) {
                e.stopPropagation(); 
                
                if (window.speechSynthesis.speaking) {
                    window.speechSynthesis.cancel();
                    document.querySelectorAll('.btn-speaker').forEach(b => b.classList.remove('playing'));
                } else {
                    document.querySelectorAll('.btn-speaker-front, .btn-speaker').forEach(b => b.classList.remove('playing'));
                    btnBack.classList.add('playing');
                    
                    currentUtterance = new SpeechSynthesisUtterance(item.tts);
                    currentUtterance.lang = 'hu-HU';
                    currentUtterance.rate = 0.90; 
                    
                    currentUtterance.onend = function() {
                        btnBack.classList.remove('playing');
                    };
                    
                    window.speechSynthesis.speak(currentUtterance);
                }
            });

            grid.appendChild(card);
        });

        setTimeout(() => {
            if (window.MathJax && window.MathJax.typesetPromise) {
                window.MathJax.typesetPromise().catch(err => console.log(err));
            }
        }, 100);
    }

    function updateRank() {
        const ranks = ["ÚJONC VIZSGÁLÓ", "LABORÁNS SEGÉD", "SZAKÍTÓ MESTER", "ANYAGMÉRNÖK", "FŐMÉRNÖK"];
        const idx = Math.min(Math.floor(xp / 150), ranks.length - 1);
        document.getElementById('rank').innerText = ranks[idx];
    }

    window.onload = init;
</script>

</body>
</html>
